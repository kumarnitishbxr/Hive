# ==========================================
# StartupOps Client - Environment Variables Template
# ==========================================

# Base API endpoint for data requests (Render backend API URL)
VITE_API_URL=http://localhost:5100/api

# WebSocket server connection URL for real-time events (Render backend base domain URL)
# If left blank, it will attempt to derive it from VITE_API_URL or use the window origin.
VITE_SOCKET_URL=http://localhost:5100
