# ==========================================
# StartupOps - Environment Variables Template
# ==========================================

# --- Server Configuration ---
# The environment to run the server in (development | production)
NODE_ENV=development
# The port the server will bind to
PORT=5100

# --- Databases & Message Queues ---
# MongoDB connection URI (e.g. MongoDB Atlas cluster or local mongodb instance)
MONGODB_URI=mongodb://localhost:27017/startupops

# Redis Configuration (Render supports REDIS_URL)
# If REDIS_URL is provided, it takes precedence over REDIS_HOST/PORT/PASSWORD.
REDIS_URL=redis://localhost:6379
# Fallback Redis settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Qdrant Vector DB Configuration (for AI embeddings and semantic search)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# --- Authentication & Security ---
# Secret keys for signing JWT access and refresh tokens
JWT_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
# Token expiration durations (e.g. 24h, 7d)
JWT_EXPIRY=24h

# --- CORS & Client Configuration ---
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# The main application frontend URL
CLIENT_URL=http://localhost:5173

# --- AI & Integration APIs ---
# OpenAI API Key (used for advanced LLM planner features)
OPENAI_API_KEY=your_openai_api_key_here
# Gemini API Key (used for embeddings and primary LLM responses)
GEMINI_API=your_gemini_api_key_here

# --- Cloudinary Asset Storage ---
# Connection string for Cloudinary CDN integrations
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# --- Mail Delivery Service (SMTP) ---
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM="StartupOps <no-reply@startupops.app>"
